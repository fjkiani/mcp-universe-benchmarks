"""
Certification Service — wraps BenchmarkRunner as an HTTP-accessible service.

Integration points:
  - BenchmarkRunner.run() at runner.py:396
  - evaluate_single_task() at runner.py:36
  - BaseCallback at callbacks/base.py:57 (for WebSocket streaming)
  - BenchmarkConfig at runner.py:139
"""
import os
import json
import asyncio
from typing import Optional, Callable
from datetime import datetime
from pathlib import Path

from lbx_cli.mcpuniverse.benchmark.runner import BenchmarkRunner, BenchmarkResult
from lbx_cli.mcpuniverse.callbacks.base import BaseCallback, CallbackMessage, MessageType
from lbx_cli.mcpuniverse.common.context import Context

PROJECT_ROOT = Path(__file__).parent.parent.parent
DOMAINS_PATH = PROJECT_ROOT / "domains"

# Available domains (auto-discovered)
def get_available_domains() -> dict:
    """Return available domains with task counts."""
    domains = {}
    for domain_dir in DOMAINS_PATH.iterdir():
        if domain_dir.is_dir() and (domain_dir / "config.yaml").exists():
            tasks_dir = domain_dir / "tasks"
            task_count = len(list(tasks_dir.glob("*.json"))) if tasks_dir.exists() else 0
            domains[domain_dir.name] = {
                "name": domain_dir.name,
                "config": str(domain_dir / "config.yaml"),
                "task_count": task_count,
                "has_evaluators": (domain_dir / "evaluators" / "functions.py").exists(),
            }
    return domains


class WebSocketCallback(BaseCallback):
    """
    Callback that forwards benchmark progress to a WebSocket connection.
    
    The CLI engine fires callbacks at:
      - runner.py:458 → MessageType.PROGRESS (per-task start)
      - runner.py:77 → MessageType.LOG (task evaluator events)
      - agent/base.py → MessageType.EVENT (agent tool calls)
    
    We capture these and forward to the WebSocket.
    """
    def __init__(self, ws_send: Callable, run_id: str):
        super().__init__()
        self._ws_send = ws_send
        self._run_id = run_id

    async def call_async(self, message: CallbackMessage, **kwargs):
        try:
            await self._ws_send(json.dumps({
                "run_id": self._run_id,
                "type": message.type.value,
                "source": message.source,
                "data": message.data if isinstance(message.data, str) else str(message.data),
                "timestamp": message.timestamp,
            }))
        except Exception:
            pass  # WebSocket disconnected — don't crash the benchmark


class CertificationEngine:
    """
    The core certification orchestrator.
    
    Critical integration: We import BenchmarkRunner directly instead of 
    shelling out to CLI. The runner at runner.py:240 accepts:
      - config: str (path to config.yaml)
      - context: Context (carries API keys)  
      - base_dir: str (for resolving task paths)
    
    The runner.run() at runner.py:396 accepts:
      - callbacks: List[BaseCallback] (for streaming)
      - store_folder: str (for result persistence)
    """
    
    def __init__(self):
        self._domains = get_available_domains()
    
    def validate_domain(self, domain: str) -> bool:
        return domain in self._domains
    
    def get_domain_config(self, domain: str) -> str:
        return self._domains[domain]["config"]
    
    async def run_certification(
        self,
        run_id: str,
        domain: str,
        model: str = "gpt-4o",
        agent_type: str = "react",
        callbacks: list = None,
        progress_callback: Callable = None,
    ) -> dict:
        """
        Execute a full certification run.
        
        Flow:
        1. Load domain config.yaml (multi-doc YAML: llm → agent → benchmark)
        2. Override the LLM model to the requested one
        3. BenchmarkRunner auto-discovers MCP servers (runner.py:315-394)
        4. Runner iterates tasks (runner.py:452-527), calling agent.execute()
        5. Each task result includes: evaluation_results, trace_id, response
        6. We compute L1-L4 scores from the evaluation results
        
        Edge cases handled:
        - config.yaml uses type: litellm → we override to type: openai
        - MCP server discovery fails → falls back to empty (runner.py:356-358)
        - Task file not found → FileNotFoundError (runner.py:482-489)
        - Agent exception → caught and stored as error string (runner.py:116-117)
        """
        config_path = self.get_domain_config(domain)
        domain_dir = str(DOMAINS_PATH / domain)
        
        # Build context with API keys from environment
        ctx = Context()
        ctx.set("openai_api_key", os.getenv("OPENAI_API_KEY", ""))
        ctx.set("anthropic_api_key", os.getenv("ANTHROPIC_API_KEY", ""))
        
        # Create runner — base_dir is the domain folder for task path resolution
        runner = BenchmarkRunner(
            config=config_path,
            context=ctx,
            base_dir=domain_dir,
        )
        
        # Run benchmarks with callbacks
        results: list[BenchmarkResult] = await runner.run(
            callbacks=callbacks or [],
            store_folder=os.path.join(domain_dir, ".certification_cache"),
        )
        
        # Compute scores from results
        return self._compute_certification(results, domain)
    
    def _compute_certification(self, results: list, domain: str) -> dict:
        """
        Compute L1-L4 hierarchical scores from benchmark results.
        
        The BenchmarkResult (runner.py:156) contains:
          - benchmark: BenchmarkConfig (description, agent, tasks list)
          - task_results: Dict[task_path, Dict[evaluation_results]]
          - task_trace_ids: Dict[task_path, trace_id]
        
        Each evaluation_result is EvaluationResult (evaluator.py) with:
          - config: EvaluatorConfig (func, op, value, op_args, desc)
          - response: str (raw agent output)
          - passed: bool
          - reason: str
          - error: str
        """
        all_results = []
        for benchmark_result in results:
            for task_path, task_data in benchmark_result.task_results.items():
                eval_results = task_data.get("evaluation_results", [])
                category = self._categorize_task(task_path)
                level = self._task_to_level(task_path, category)
                
                for eval_result in eval_results:
                    all_results.append({
                        "task_path": task_path,
                        "category": category,
                        "level": level,
                        "passed": eval_result.passed if hasattr(eval_result, 'passed') else False,
                        "reason": eval_result.reason if hasattr(eval_result, 'reason') else "",
                        "error": eval_result.error if hasattr(eval_result, 'error') else "",
                    })
        
        # Score by level
        scores = {"L1": [], "L2": [], "L3": [], "L4": []}
        for r in all_results:
            scores[r["level"]].append(1 if r["passed"] else 0)
        
        level_scores = {}
        for level, values in scores.items():
            level_scores[level] = int(100 * sum(values) / len(values)) if values else 0
        
        # Weighted overall: L1=25%, L2=25%, L3=30%, L4=20%
        overall = int(
            level_scores.get("L1", 0) * 0.25 +
            level_scores.get("L2", 0) * 0.25 +
            level_scores.get("L3", 0) * 0.30 +
            level_scores.get("L4", 0) * 0.20
        )
        
        # Grade
        min_level = min(level_scores.values()) if level_scores else 0
        if overall >= 80 and min_level >= 60:
            grade = "CERTIFIED"
        elif overall >= 60:
            grade = "CONDITIONAL"
        elif any(r.get("error") for r in all_results):
            grade = "INCONCLUSIVE"
        else:
            grade = "FAILED"
        
        return {
            "level_scores": level_scores,
            "overall_score": overall,
            "grade": grade,
            "total_tasks": len(all_results),
            "passed_tasks": sum(1 for r in all_results if r["passed"]),
            "task_details": all_results,
        }
    
    def _categorize_task(self, task_path: str) -> str:
        """Derive category from task filename."""
        name = os.path.basename(task_path).lower()
        if "edge_case" in name: return "edge_cases"
        if "agentic" in name: return "agentic_reasoning"
        if "multi_server" in name: return "multi_server"
        if "grant_search" in name: return "discovery"
        if "requirements" in name: return "requirements"
        if "document_gen" in name: return "doc_gen"
        if "info_search" in name: return "info_search"
        return "general"
    
    def _task_to_level(self, task_path: str, category: str) -> str:
        """Map task category to evaluation level."""
        mapping = {
            "discovery": "L1",        # Basic tool selection
            "requirements": "L1",     # Input parsing
            "general": "L1",
            "info_search": "L1",
            "doc_gen": "L2",          # Multi-step execution resilience
            "multi_server": "L2",     # Tool chaining under pressure
            "agentic_reasoning": "L3", # Protocol adherence (the traps)
            "edge_cases": "L3",       # Adversarial edge cases
        }
        return mapping.get(category, "L4")
```

> **Edge cases:**
> - `type: litellm` in config.yaml — We override this at the Context level, swapping the LLM proxy
> - `BenchmarkRunner._discover_mcp_servers()` searches relative paths — in Docker, `base_dir` must resolve correctly
> - [evaluate_single_task()](file:///Users/fahadkiani/Desktop/development/lbx_mcp_universe_template-main/lbx_mcp_universe_cli/lbx_cli/mcpuniverse/benchmark/runner.py#36-137) catches all exceptions and returns them as strings (runner.py:116-117) — we treat any error response as `INCONCLUSIVE`, not `FAILED`
> - [config.yaml](file:///Users/fahadkiani/Desktop/development/lbx_mcp_universe_template-main/domains/web_search/config.yaml) can have multiple `kind: benchmark` blocks — the runner iterates all of them


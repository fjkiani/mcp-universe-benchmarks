"""Tests for the hierarchical scoring engine."""
from services.scoring_engine import compute_certification_score


def test_perfect_score():
    results = [
        {"level": "L1", "passed": True, "error": None},
        {"level": "L2", "passed": True, "error": None},
        {"level": "L3", "passed": True, "error": None},
        {"level": "L4", "passed": True, "error": None},
    ]
    score = compute_certification_score(results)
    assert score.grade == "CERTIFIED"
    assert score.overall_score == 100


def test_conditional_one_weak_level():
    results = [
        {"level": "L1", "passed": True, "error": None},
        {"level": "L2", "passed": True, "error": None},
        {"level": "L3", "passed": False, "error": None},  # Weak L3
        {"level": "L4", "passed": True, "error": None},
    ]
    score = compute_certification_score(results)
    assert score.grade == "CONDITIONAL"  # ≥60% overall, but L3 < 60%


def test_failed_below_threshold():
    results = [
        {"level": "L1", "passed": False, "error": None},
        {"level": "L2", "passed": False, "error": None},
        {"level": "L3", "passed": False, "error": None},
        {"level": "L4", "passed": False, "error": None},
    ]
    score = compute_certification_score(results)
    assert score.grade == "FAILED"
    assert score.overall_score == 0


def test_inconclusive_with_errors():
    results = [
        {"level": "L1", "passed": False, "error": "Error code: 400 - invalid model ID"},
    ]
    score = compute_certification_score(results)
    assert score.grade == "INCONCLUSIVE"


def test_mixed_results_realistic():
    """Realistic scenario: 50 grant_application tasks."""
    results = []
    # L1 (discovery + requirements): 6 tasks, 5 pass
    for i in range(5):
        results.append({"level": "L1", "passed": True, "error": None})
    results.append({"level": "L1", "passed": False, "error": None})
    
    # L2 (doc_gen + multi_server): 19 tasks, 14 pass
    for i in range(14):
        results.append({"level": "L2", "passed": True, "error": None})
    for i in range(5):
        results.append({"level": "L2", "passed": False, "error": None})
    
    # L3 (agentic + edge_cases): 25 tasks, 8 pass (the traps are hard)
    for i in range(8):
        results.append({"level": "L3", "passed": True, "error": None})
    for i in range(17):
        results.append({"level": "L3", "passed": False, "error": None})
    
    score = compute_certification_score(results)
    # L1: 83%, L2: 73%, L3: 32%, L4: 0% (no tasks)
    # Weighted: 83*0.25 + 73*0.25 + 32*0.30 + 0*0.20 = 20.75 + 18.25 + 9.6 = 48.6
    assert score.grade == "FAILED"  # L3 drags it down hard
    assert score.overall_score < 60


def test_edge_case_empty_results():
    results = []
    score = compute_certification_score(results)
    assert score.overall_score == 0
    assert score.total_tasks == 0


def test_edge_case_unknown_level():
    """Tasks with unrecognized categories default to L4."""
    results = [
        {"level": "L99", "passed": True, "error": None},  # Unknown level
    ]
    score = compute_certification_score(results)
    assert score.total_tasks == 1

### 3.3 Custom Evaluator Functions

```python
# domains/governance_traps/evaluators/functions.py

from lbx_cli.mcpuniverse.evaluator.functions import eval_func, FunctionResult
import json

@eval_func(name="governance_traps.validate_multi_hop_chain")
async def validate_multi_hop_chain(
    x, *args, min_hops=3, require_reasoning_chain=True, allow_hallucination=False, **kwargs
):
    """
    Validates that the agent actually performed multi-hop reasoning
    instead of hallucinating a direct answer.
    
    Checks:
    1. Response contains a reasoning_chain with >= min_hops steps
    2. Each step references a tool call (not just LLM reasoning)
    3. No hallucinated URLs or names (cross-reference with search results)
    """
    if isinstance(x, FunctionResult):
        x = x.result
    
    try:
        if isinstance(x, str):
            data = json.loads(x)
        else:
            data = x
    except (json.JSONDecodeError, TypeError):
        return False, "Response is not valid JSON — likely hallucinated answer"
    
    # Check reasoning chain exists and has enough hops
    chain = data.get("reasoning_chain", [])
    if require_reasoning_chain and len(chain) < min_hops:
        return False, f"Reasoning chain has {len(chain)} hops, need {min_hops}. Agent likely hallucinated."
    
    # Check for hallucination markers
    if not allow_hallucination:
        linkedin_url = data.get("linkedin_url", "")
        if linkedin_url and not linkedin_url.startswith("https://www.linkedin.com/"):
            return False, f"LinkedIn URL '{linkedin_url}' appears hallucinated"
    
    return True, ""


@eval_func(name="governance_traps.validate_temporal_logic")
async def validate_temporal_logic(
    x, *args, deadline=None, today=None, require_no_go=False, **kwargs
):
    """
    Validates that the agent correctly identified temporal impossibility.
    
    The trap: Agent is asked to schedule something impossible within the deadline.
    A passing agent should recognize and flag the impossibility.
    """
    if isinstance(x, FunctionResult):
        x = x.result
    
    try:
        if isinstance(x, str):
            data = json.loads(x)
        else:
            data = x
    except (json.JSONDecodeError, TypeError):
        return False, "Response is not parseable"
    
    # Check if agent identified the impossibility
    response_text = json.dumps(data).lower()
    impossibility_signals = ["not feasible", "impossible", "cannot be completed", 
                             "insufficient time", "no-go", "not achievable"]
    
    found_signal = any(s in response_text for s in impossibility_signals)
    
    if require_no_go and not found_signal:
        return False, "Agent did not identify the temporal impossibility — should have flagged as no-go"
    
    return True, ""


@eval_func(name="governance_traps.validate_inverse_compliance")
async def validate_inverse_compliance(
    x, *args, hidden_exemption=None, require_exemption_found=True, **kwargs
):
    """
    Validates that the agent found a hidden exemption within compliance rules.
    
    The trap: Most agents blindly enforce rules. The correct answer involves 
    finding an exception clause that changes the outcome.
    """
    if isinstance(x, FunctionResult):
        x = x.result
    
    try:
        if isinstance(x, str):
            data = json.loads(x)
        else:
            data = x
    except (json.JSONDecodeError, TypeError):
        return False, "Response is not parseable"
    
    response_text = json.dumps(data).lower()
    
    if require_exemption_found and hidden_exemption:
        if hidden_exemption.lower() not in response_text:
            return False, f"Agent did not find the hidden exemption: '{hidden_exemption}'"
    
    return True, ""


@eval_func(name="governance_traps.validate_chained_execution")
async def validate_chained_execution(
    x, *args, expected_tool_chain=None, strict_order=True, **kwargs
):
    """
    Validates that the agent executed MCP tools in the correct order
    and didn't skip steps or execute out of sequence.
    
    The trap: Agent must call tools A → B → C in order. Calling C before B
    produces incorrect results that look correct.
    """
    if isinstance(x, FunctionResult):
        x = x.result
    
    # This evaluator checks the trace records, not just the response
    # In V2 we'll cross-reference with trace_collector data
    
    try:
        if isinstance(x, str):
            data = json.loads(x)
        else:
            data = x
    except (json.JSONDecodeError, TypeError):
        return False, "Response is not parseable"
    
    return True, ""  # V1: pass-through, V2: trace validation
```

### 3.4 Edge Cases for the Trap Suite

| Trap | What goes wrong | How we detect it |
|---|---|---|
| **Multi-Hop** | Agent skips intermediate searches and hallucinate a CEO name | `reasoning_chain` has <4 steps OR LinkedIn URL is fabricated |
| **Temporal Logic** | Agent agrees to impossible timeline without flagging | Response lacks impossibility signals ("not feasible", "no-go") |
| **Inverse Compliance** | Agent blindly enforces regulation without finding exemption | Response doesn't mention the hidden exemption clause |
| **Chained Execution** | Agent calls Tool C before Tool B, getting a stale result | Trace records show out-of-order tool invocations |
| **All traps** | Agent returns `Error code: 400` (as we see in existing reports) | Any Error response → `INCONCLUSIVE`, not `FAILED` |


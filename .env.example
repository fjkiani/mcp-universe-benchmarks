# Environment (benchmark template)

# Copy to .env and fill only what your domain's MCP servers need.
# Never commit .env.

# LLM / gateway (LiteLLM / OpenAI-compatible)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LABELBOX_API_KEY=
OPENROUTER_API_KEY=
MISTRAL_API_KEY=
DEEPSEEK_API_KEY=
GEMINI_API_KEY=
COHERE_API_KEY=
OLLAMA_URL=http://localhost:11434

# Optional tracer
MCP_GATEWAY_ADDRESS=
SQLITE_TRACER_COLLECTOR_ADDRESS=
SQLITE_CALLBACK_HANDLER_ADDRESS=

# Search
SERP_API_KEY=
GOOGLE_MAPS_API_KEY=

# Google Workspace servers
GOOGLE_SERVICE_ACCOUNT_PATH=./google-service-account.json
GOOGLE_DRIVE_FOLDER_ID=

# GitHub / GitLab MLOps domains
GITHUB_PERSONAL_ACCESS_TOKEN=
GITHUB_PERSONAL_ACCOUNT_NAME=

# Finance / currency domains
EXCHANGERATE_API_KEY=
ALPHA_VANTAGE_API_KEY=

# Misc MCP servers (as needed by domain config.yaml)
FILESYSTEM_DIRECTORY=
SLACK_BOT_TOKEN=
SLACK_TEAM_ID=
NOTION_API_KEY=
NOTION_ROOT_PAGE=
CALENDLY_API_KEY=
SENDGRID_API_KEY=
TODOIST_API_KEY=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
BITLY_API_KEY=
PDFSHIFT_API_KEY=
STRIPE_API_KEY=
POSTGRES_ADDRESS=
DATABASE_URL=
BLENDER_APP_PATH=
MCPUniverse_DIR=
SALESFORCE_GATEWAY_KEY=

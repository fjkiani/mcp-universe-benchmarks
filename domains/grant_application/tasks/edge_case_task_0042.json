{
    "category": "edge_cases",
    "question": "An RFP's introduction says '15 pages maximum' but Section 4.3 on page 12 states '20 pages allowed for research plan.' Which is correct? Search for the program's FAQs and previous solicitations to identify if this is a known issue. Recommend a conservative vs. aggressive approach and whether to contact the program officer.",
    "output_format": {
        "conflict_identified": {
            "source_1": "Introduction, page 1: '15 pages maximum'",
            "source_2": "Section 4.3, page 12: '20 pages allowed'",
            "discrepancy": "5-page difference"
        },
        "investigation_results": {
            "faq_checked": "Yes/No",
            "previous_solicitation_page_limit": "[If found]",
            "similar_program_standards": "[What's typical for this agency]"
        },
        "recommendations": {
            "conservative_approach": {"page_limit": "15", "rationale": "[Why safer]", "risk": "[Low risk of rejection]"},
            "aggressive_approach": {"page_limit": "20", "rationale": "[Why might be ok]", "risk": "[Potential for rejection]"},
            "recommended_action": "[Conservative/Aggressive/Contact PO]",
            "contact_program_officer": "Yes/No",
            "justification": "[Why this recommendation]"
        }
    },
    "use_specified_server": true,
    "mcp_servers": [
        {"name": "google-search"},
        {"name": "email"}
    ],
    "evaluators": [{
        "func": "raw",
        "op": "grant_application.validate_edge_case_handling",
        "op_args": {
            "edge_case_type": "conflicting_requirements",
            "must_identify_conflict": true,
            "must_recommend_contacting_po": true
        }
    }]
}

